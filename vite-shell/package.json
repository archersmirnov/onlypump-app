{
  "name": "onlypump-vite-shell",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check:api": "node scripts/check-shared-api.mjs",
    "check:legacy-api": "node scripts/check-legacy-api-client.mjs",
    "check:workouts": "node scripts/check-workout-normalize.mjs",
    "check:workout-mapper": "node scripts/check-workout-mapper.mjs",
    "check:workout-repository": "node scripts/check-workout-repository.mjs",
    "check:workout-sync": "node scripts/check-workout-sync.mjs",
    "check": "pnpm run check:api && pnpm run check:legacy-api && pnpm run check:workouts && pnpm run check:workout-mapper && pnpm run check:workout-repository && pnpm run check:workout-sync && pnpm run build"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "vite": "^8.1.0"
  }
}
